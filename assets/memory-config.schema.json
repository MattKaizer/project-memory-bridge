{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/project-memory-bridge/memory-config.schema.json",
  "title": "Project Memory Bridge Config",
  "type": "object",
  "additionalProperties": true,
  "required": ["project", "memory"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "root"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "root": { "type": "string", "minLength": 1 },
        "managed_by": { "type": "string" },
        "primary_agent": { "type": "string" }
      }
    },
    "memory": {
      "type": "object",
      "required": ["engram", "obsidian", "graphify"],
      "properties": {
        "engram": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "pointer_mode": {
              "type": "string",
              "enum": ["compact", "disabled"],
              "default": "compact"
            }
          }
        },
        "obsidian": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "vault_root": { "type": "string" },
            "project_dir": { "type": "string" }
          }
        },
        "graphify": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "local_output_dir": { "type": "string", "default": "graphify-out" },
            "install_if_missing": { "type": "boolean", "default": false },
            "force_graphify_on_init": { "type": "boolean", "default": false }
          }
        },
        "compact": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "default_strategy": {
              "type": "string",
              "enum": ["compact-first", "graph-first"],
              "default": "compact-first"
            },
            "scenario_default": {
              "type": "string",
              "default": "focused-task"
            },
            "max_tokens_per_artifact": {
              "type": "integer",
              "minimum": 100,
              "default": 400
            },
            "max_artifacts_per_request": {
              "type": "integer",
              "minimum": 1,
              "default": 3
            },
            "auto_refresh_days": {
              "type": "integer",
              "minimum": 1,
              "default": 7
            },
            "routing_file": {
              "type": "string",
              "default": ".atl/compact-routing.json"
            },
            "router_note": {
              "type": "string",
              "default": "notes/00_Project_Index.md"
            }
          }
        }
      }
    }
  }
}
